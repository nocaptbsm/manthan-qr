# ============================================================================
# ManthanQR — Environment Variables Template
# ============================================================================

# ---- Frontend (.env.local) ----
# Place these in frontend/.env.local

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_API_URL=http://localhost:5000/api
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Backend (.env) ----
# Place these in backend/.env

NODE_ENV=development
PORT=5000

# Supabase (use service_role key for backend)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# CORS
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=debug

# Token Settings
TOKEN_EXPIRY_SECONDS=30
TOKEN_CLEANUP_INTERVAL_MS=300000

# ---- ESP32 (config.h) ----
# Configure in esp32/config.h

# WIFI_SSID=YourWiFiNetwork
# WIFI_PASSWORD=YourWiFiPassword
# API_BASE_URL=https://your-backend.onrender.com/api
# DEVICE_CODE=DEV-MLH-001
# DEVICE_SECRET=secret_mlh_001
# REFRESH_INTERVAL_SECONDS=30
